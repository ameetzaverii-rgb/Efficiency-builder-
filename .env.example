# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Microsoft 365 / Graph ----
MICROSOFT_CLIENT_ID=your-client-id
MICROSOFT_CLIENT_SECRET=your-client-secret
MICROSOFT_TENANT_ID=your-tenant-id
MICROSOFT_REDIRECT_URI=https://your-app.vercel.app/api/auth/callback
MICROSOFT_REFRESH_TOKEN=

# ---- AI (drafting, analysis, brief) ----
# Set EITHER of these. If GEMINI_API_KEY is present it is used; else ANTHROPIC_API_KEY.
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash   # optional override
ANTHROPIC_API_KEY=sk-ant-...

# ---- Jira (Atlassian Cloud) ----
JIRA_BASE_URL=https://your-site.atlassian.net
JIRA_EMAIL=you@getsetlearn.info
JIRA_API_TOKEN=

# ---- Secrets for protected endpoints ----
CRON_SECRET=generate-a-long-random-string
WEBHOOK_SECRET=generate-a-long-random-string
